# Режим работы AI-провайдера
# true - используется мок (не требует API ключей, для демонстрации flow)
# false - используется реальный AI API (нужен OPENAI_API_KEY)
USE_MOCK_AI=true

# Настройки приложения
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# OpenAI API (если USE_MOCK_AI=false)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini